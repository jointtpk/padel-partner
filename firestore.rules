rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── MVP-TESTING RULES ────────────────────────────────────────────────
    // These rules are intentionally permissive: any authenticated user can
    // read/write under our known collections. We need this because the
    // app pins a *deterministic* sync UID per email (so the same login
    // resolves to the same identity across devices) which doesn't match
    // the anonymous Firebase auth.uid. Strict rules of the form
    // `hostUid == auth.uid` were rejecting every cross-device write.
    //
    // BEFORE PRODUCTION: tighten these. Either move to Firebase email-link
    // / phone auth (so auth.uid == sync UID by construction), or store
    // the auth.uid → email mapping server-side and validate writes via a
    // Cloud Function. See TODO.md → P0 → "Firestore security rules".

    match /games/{gameId} {
      allow read, write: if request.auth != null;

      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    match /dms/{conversationId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Default-deny anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
