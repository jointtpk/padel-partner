rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Game documents — readable by any signed-in user (deep-link recipients
    // need this). Writes restricted to the host, identified by hostUid.
    match /games/{gameId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.id is string
        && request.resource.data.club is string;

      allow update: if request.auth != null
        && resource.data.hostUid == request.auth.uid
        && request.resource.data.hostUid == resource.data.hostUid;

      allow delete: if request.auth != null
        && resource.data.hostUid == request.auth.uid;

      // Join requests subcollection. Doc id is the requester's auth.uid.
      match /requests/{requesterUid} {

        allow read: if request.auth != null && (
          request.auth.uid == requesterUid
          || request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid
        );

        // Only the requester can create their own request, and it must
        // start in 'pending' state.
        allow create: if request.auth != null
          && request.auth.uid == requesterUid
          && request.resource.data.userId == requesterUid
          && request.resource.data.status == 'pending';

        // Status changes (approve/decline) belong to the host.
        allow update: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.status in ['approved', 'declined', 'pending'];

        // Either side can delete: requester to cancel, host to clean up.
        allow delete: if request.auth != null
          && (request.auth.uid == requesterUid
              || request.auth.uid == get(/databases/$(database)/documents/games/$(gameId)).data.hostUid);
      }
    }

    // Default-deny anything not explicitly allowed above. Add new
    // collections (chats, friends, etc.) when wiring those features.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
